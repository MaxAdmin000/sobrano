# Robokassa credentials from shop technical settings.
ROBOKASSA_MERCHANT_LOGIN=your_shop_login
ROBOKASSA_PASSWORD1=your_password_1
ROBOKASSA_PASSWORD2=your_password_2

# Use the special test passwords from Robokassa technical settings when IS_TEST=1.
ROBOKASSA_IS_TEST=1
ROBOKASSA_HASH_ALGORITHM=md5
ROBOKASSA_CULTURE=ru

# Public domain(s) разрешённые для CORS, comma-separated. В проде — конкретные.
# Example: https://sobrano.store,https://www.sobrano.store
ALLOWED_ORIGINS=*

# ----- Админка -----
# Логин и SHA-256 хеш пароля. Генерация хеша:
#   echo -n 'мой-пароль' | shasum -a 256 | awk '{print $1}'
ADMIN_LOGIN=admin
ADMIN_PASSWORD_HASH=

# Optional webhook for CRM/Telegram/Zapier/Make/custom backend.
ORDER_WEBHOOK_URL=
ORDER_WEBHOOK_SECRET=

# Fiscalization defaults. Keep empty SNO if it is configured in Robokassa cabinet.
ROBOKASSA_SNO=
ROBOKASSA_DEFAULT_TAX=none
ROBOKASSA_DEFAULT_PAYMENT_METHOD=full_prepayment
ROBOKASSA_DEFAULT_PAYMENT_OBJECT=commodity

# Delivery lines charged inside the Robokassa payment.
DELIVERY_OWN_PRICE=500.00
DELIVERY_PICKUP_PRICE=0.00
DELIVERY_YANDEX_PRICE=0.00

# If true, backend accepts product prices from browser when SKU is absent from products.json.
# Keep false for production.
ALLOW_CLIENT_PRICES=false

# Local server.
PORT=8787
